{
  "name": "cdf-application-template-react",
  "version": "1.0.0",
  "description": "A react application template for CDF",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:clean": "pkill -f \"dev-with-fusion.js\" || true; pkill -f \"npx vite\" || true; pkill -f \"vite --port 1988\" || true; rm -rf node_modules/.vite; npm run start:fusion",
    "start:fusion": "node dev-with-fusion.js",
    "dev:fusion": "node dev-with-fusion.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx cdf-deploy",
    "deploy:verbose": "npx cdf-deploy --verbose",
    "deploy:ci": "npx cdf-deploy --ci",
    "deploy:ci:verbose": "npx cdf-deploy --ci --verbose",
    "deploy:ci:build": "npm run build && npx cdf-deploy --ci",
    "deploy:help": "npx cdf-deploy --help",
    "deploy:build": "npm run build && npx cdf-deploy",
    "deploy:legacy": "node deploy.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests specified yet\" && exit 0",
    "test:e2e": "echo \"E2E tests not configured yet\" && exit 0"
  },
  "dependencies": {
    "@cognite/atlas-ai": "file:../../../Documents/GitHub/fusion/libs/shared/atlas-ai",
    "@cognite/sdk": "^10.0.0",
    "@tanstack/react-query": "^5.85.5",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "cdf-design-system-alpha": "^0.0.2",
    "dune-fe-auth": "^0.5.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/archiver": "^6.0.2",
    "@types/node": "^24.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "archiver": "^7.0.1",
    "dotenv": "^16.6.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "open": "^10.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.2.2",
    "vite": "^7.1.7",
    "yargs": "^17.7.2"
  }
}
